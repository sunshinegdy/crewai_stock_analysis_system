# LLM 配置（默认使用通义千问）
LLM_PROVIDER=qwen            # 可选: qwen | openai
QWEN_API_KEY=your-dashscope-api-key-here
QWEN_MODEL_NAME=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：LiteLLM 代理（如有自建代理，可以通过它统一转发）
# LITELLM_PROXY_URL=http://localhost:8000

# 如果切换到 OpenAI，可在此填写
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL_NAME=gpt-4o

# Serper API配置（用于网络搜索）
SERPER_API_KEY=your-serper-api-key-here

# 系统配置
DEBUG=True
LOG_LEVEL=INFO

# 缓存配置
CACHE_ENABLED=True
CACHE_TTL=3600

# 监控配置
MONITORING_ENABLED=True
MONITORING_INTERVAL=300

# Web界面配置
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=True

# 数据库配置（可选）
DATABASE_URL=sqlite:///stock_analysis.db

# 邮件通知配置（可选）
EMAIL_ENABLED=False
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM_EMAIL=your-email@gmail.com
EMAIL_TO_EMAILS=recipient1@gmail.com,recipient2@gmail.com
